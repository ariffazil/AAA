prefix_rule(pattern=["C:\\Program Files\\PowerShell\\7\\pwsh.exe", "-Command", "$ledger = Join-Path $env:TEMP 'codex_ledger_smoke.jsonl'; @'\nfrom pathlib import Path\nfrom arifos_core.codex_ledger import log_codex_cli_entry\n\nfloors = {\n    \"F0_anti_janitor\": \"PASS\",\n    \"F1_amanah\": \"PASS\",\n    \"F2_truth\": 0.99,\n    \"F3_peace2\": 1.2,\n    \"F4_delta_s\": 0.1,\n    \"F5_kappa_r\": 0.97,\n    \"F6_omega0\": 0.04,\n    \"F7_rasa\": \"PASS\",\n    \"F8_tri_witness\": 0.98,\n    \"F9_anti_hantu\": \"PASS\",\n}\n\npath = Path(r\"'\" + $ledger + \"'\")\nlog_codex_cli_entry(\n    floors=floors,\n    verdict=\"SEAL\",\n    task_type=\"code_gen\",\n    task_description=\"smoke entry 1\",\n    scope=\"a.py\",\n    risk_score=0.0,\n    entropy_delta=0.0,\n    reversible=True,\n    artifacts=[\"a.py\"],\n    query=\"smoke1\",\n    candidate_output=\"a\",\n    pipeline_path=[\"CODEX_CLI\"],\n    ledger_path=path,\n    job_id=\"codex-smoke-1\",\n)\nlog_codex_cli_entry(\n    floors=floors,\n    verdict=\"SEAL\",\n    task_type=\"code_gen\",\n    task_description=\"smoke entry 2\",\n    scope=\"b.py\",\n    risk_score=0.0,\n    entropy_delta=0.0,\n    reversible=True,\n    artifacts=[\"b.py\"],\n    query=\"smoke2\",\n    candidate_output=\"b\",\n    pipeline_path=[\"CODEX_CLI\"],\n    ledger_path=path,\n    job_id=\"codex-smoke-2\",\n)\nprint(f\"Ledger path: {path}\")\nprint(f\"Entries: {sum(1 for _ in path.open())}\")\n'@ | python -\narifos-verify-ledger --ledger $ledger"], decision="allow")
