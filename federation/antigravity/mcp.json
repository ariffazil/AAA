{
  "servers": {
    "arifOS": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-m",
        "arifosmcp.runtime",
        "stdio"
      ],
      "cwd": "C:\\ariffazil\\arifOS",
      "env": {
        "PYTHONPATH": "C:\\ariffazil\\arifOS",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1",
        "ARIFOS_VAULT_PATH": "C:\\ariffazil\\arifOS\\arifosmcp\\VAULT999",
        "ARIFOS_CONSTITUTIONAL_MODE": "AAA",
        "ARIFOS_GOVERNANCE_SECRET": "arifos-internal-forge-secret",
        "AAA_MCP_TRANSPORT": "stdio"
      }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "github-official": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\ariffazil",
        "C:\\Users\\User\\Downloads"
      ]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "C:\\ariffazil\\arifOS\\arifosmcp\\VAULT999\\mcp-memory.json"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {
        "PLAYWRIGHT_HEADLESS": "true"
      }
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    },
    "perplexity": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    },
    "time": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ]
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "desktop-commander"
      ]
    },
    "GitKraken": {
      "type": "stdio",
      "command": "c:\\Users\\User\\AppData\\Roaming\\Antigravity\\User\\globalStorage\\eamodio.gitlens\\gk.exe",
      "args": [
        "mcp",
        "--host=antigravity",
        "--source=gitlens",
        "--scheme=antigravity"
      ]
    },
    "a-forge": {
      "type": "stdio",
      "command": "node",
      "args": [
        "C:\\ariffazil\\A-FORGE\\dist\\src\\mcp\\cli.js",
        "serve",
        "--transport",
        "stdio"
      ],
      "env": {
        "NODE_ENV": "development",
        "ARIFOS_GOVERNANCE_URL": "https://mcp.arif-fazil.com/mcp"
      }
    }
  },
  "inputs": []
}
