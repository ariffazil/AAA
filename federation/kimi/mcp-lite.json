{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "web-search": {
      "command": "node",
      "args": [
        "C:/Users/User/.kimi/mcp-servers/web-search/build/index.js"
      ]
    }
  }
}