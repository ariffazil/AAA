{
  "$schema": "arifOS/agent-card/v2.0.0",
  "id": "qwen-code",
  "name": "Qwen Code CLI",
  "description": "Qwen Code CLI forge instrument on af-forge. Bound to AAA as a bridge-mode FI citizen for observe/reason/draft work under F1-F13.",
  "version": "1.0.0",
  "model": "qwen / MiniMax-M3 bridge",
  "binary": "/root/.npm-global/bin/qwen",
  "tier": "FI",
  "role": "forge_instrument",
  "class": "CODING/FI",
  "protocolVersion": "1.0.1",
  "url": "https://aaa.arif-fazil.com/a2a/qwen-code",
  "provider": {
    "organization": "arifOS Federation",
    "url": "https://arif-fazil.com"
  },
  "defaultInputModes": [
    "text/plain",
    "application/json"
  ],
  "defaultOutputModes": [
    "text/plain",
    "application/json"
  ],
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "authenticated_extended_card": true,
    "tool_calling": true,
    "mcp_native": false
  },
  "mcp_servers": [
    "arifos",
    "geox",
    "wealth",
    "well",
    "aforge"
  ],
  "autonomy_tiers": {
    "T1_auto": "read, observe, reason, draft",
    "T2_announce": "bridge config or registry/doc updates",
    "T3_888_HOLD": "mutations outside bounded lease, irreversible actions, secrets, deploys"
  }
}
