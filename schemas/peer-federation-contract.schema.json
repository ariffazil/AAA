{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/peer-federation-contract.schema.json",
  "title": "arifOS Governed P2P Federation Contract v1",
  "description": "Capability-peering contract for federation organs. Authority is peered in compute/tools/evidence, never in constitutional judgment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "peer_id",
    "authority_class",
    "capability_card",
    "lease_required",
    "reversibility_score",
    "forbidden_actions",
    "audit_sink",
    "human_veto"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "peer_id": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organ",
        "instance_id",
        "did",
        "public_key_fingerprint"
      ],
      "properties": {
        "organ": {
          "type": "string",
          "enum": [
            "arifOS",
            "AAA",
            "A-FORGE",
            "GEOX",
            "WEALTH",
            "WELL",
            "APEX",
            "HERMES"
          ]
        },
        "instance_id": {
          "type": "string",
          "format": "uuid"
        },
        "did": {
          "type": "string",
          "pattern": "^did:arifos:[a-z0-9_-]+$"
        },
        "public_key_fingerprint": {
          "type": "string",
          "minLength": 16
        }
      }
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "evidence",
        "advisory",
        "route",
        "execute",
        "judge"
      ],
      "description": "Capability peer class. Only arifOS may hold 'judge'."
    },
    "capability_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_hash",
        "tool_manifest_url",
        "allowed_action_classes",
        "max_risk_tier"
      ],
      "properties": {
        "schema_hash": {
          "type": "string",
          "minLength": 8
        },
        "constitution_hash": {
          "type": "string"
        },
        "tool_manifest_url": {
          "type": "string",
          "format": "uri"
        },
        "allowed_action_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "OBSERVE",
              "PREPARE",
              "MUTATE",
              "ATOMIC"
            ]
          }
        },
        "max_risk_tier": {
          "type": "string",
          "enum": [
            "T0",
            "T1",
            "T2",
            "T3",
            "T4",
            "T5"
          ]
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "lease_required": {
      "type": "boolean"
    },
    "reversibility_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "0 = irreversible, 1 = fully reversible. Contract minimum enforced by arifOS."
    },
    "accepted_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_id",
          "schema_url"
        ],
        "properties": {
          "schema_id": {
            "type": "string"
          },
          "schema_url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Explicit negative constraints, e.g. 'self_authorize', 'seal_without_judge', 'move_capital'."
    },
    "audit_sink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vault999_endpoint",
        "receipt_format"
      ],
      "properties": {
        "vault999_endpoint": {
          "type": "string",
          "format": "uri"
        },
        "receipt_format": {
          "type": "string",
          "const": "arifos_vault999_v2"
        },
        "nats_subject": {
          "type": "string"
        }
      }
    },
    "human_veto": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "f13_absolute",
        "override_paths"
      ],
      "properties": {
        "f13_absolute": {
          "type": "boolean",
          "const": true
        },
        "override_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "channel",
              "endpoint"
            ],
            "properties": {
              "channel": {
                "type": "string",
                "enum": [
                  "telegram",
                  "a2a_task",
                  "mcp_tool",
                  "voice"
                ]
              },
              "endpoint": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "trust_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "signed_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer",
        "signature",
        "issued_at",
        "expires_at"
      ],
      "properties": {
        "issuer": {
          "type": "string",
          "const": "arifOS-888-JUDGE"
        },
        "signature": {
          "type": "string"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
