{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/federation/v1/error",
  "title": "Federation Error Envelope v1.0",
  "description": "Structured error for fail-closed cross-organ invocation.",
  "type": "object",
  "required": ["schema_ref", "trace_id", "error_code", "error_message"],
  "properties": {
    "schema_ref": {
      "type": "string",
      "const": "arifos://schemas/federation/v1/error"
    },
    "invocation_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "session_id": {
      "type": ["string", "null"]
    },
    "error_code": {
      "type": "string",
      "enum": [
        "SESSION_MISSING", "SESSION_INVALID", "SESSION_EXPIRED",
        "AUTHORITY_INSUFFICIENT", "JUDGE_RECEIPT_MISSING",
        "HUMAN_ACK_REQUIRED", "SCHEMA_INCOMPATIBLE",
        "ORGAN_UNREACHABLE", "IDEMPOTENCY_VIOLATED",
        "DEADLINE_EXCEEDED", "PAYLOAD_INTEGRITY_FAILED",
        "REVERSIBLE_BLOCKED", "MUTATION_FORBIDDEN"
      ]
    },
    "error_message": {
      "type": "string"
    },
    "required_fields": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What fields must be provided to resolve this error"
    },
    "retry_allowed": {
      "type": "boolean",
      "default": false
    },
    "retry_after_seconds": {
      "type": ["integer", "null"],
      "minimum": 0
    }
  }
}
