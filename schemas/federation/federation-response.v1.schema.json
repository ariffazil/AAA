{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/federation/v1/response",
  "title": "Federation Response Envelope v1.0",
  "description": "Transport-neutral cross-organ response contract.",
  "type": "object",
  "required": [
    "schema_ref", "invocation_id", "trace_id", "hop_index",
    "session_id", "source_organ", "epistemic_tag", "status"
  ],
  "properties": {
    "schema_ref": {
      "type": "string",
      "const": "arifos://schemas/federation/v1/response"
    },
    "invocation_id": {
      "type": "string",
      "description": "Echo of the request invocation_id"
    },
    "parent_invocation_id": {
      "type": ["string", "null"]
    },
    "trace_id": {
      "type": "string",
      "description": "Echo of the request trace_id"
    },
    "hop_index": {
      "type": "integer",
      "minimum": 0
    },
    "session_id": {
      "type": "string",
      "description": "Authenticated session — must match request"
    },
    "actor_id": {
      "type": "string"
    },
    "source_organ": {
      "type": "string",
      "description": "Organ that produced this response"
    },
    "capability_id": {
      "type": "string"
    },
    "epistemic_tag": {
      "type": "string",
      "enum": ["OBSERVED", "COMPUTED", "ESTIMATE", "INFERRED"]
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["OK", "DEGRADED", "PARTIAL", "REFUSED", "FAILED"],
      "description": "Response status"
    },
    "status_detail": {
      "type": "string",
      "description": "Human-readable status explanation"
    },
    "result": {
      "description": "Organ-specific result payload"
    },
    "result_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 of the result for integrity verification"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-fatal warnings"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp after which result is stale"
    }
  }
}
