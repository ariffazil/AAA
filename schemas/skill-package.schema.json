{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/skill-package.schema.json",
  "title": "AAA Skill Package Catalog",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "name": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "description": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "skills": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "id": {
                  "$ref": "./common.schema.json#/$defs/id"
                },
                "name": {
                  "$ref": "./common.schema.json#/$defs/nonEmptyString"
                },
                "version": {
                  "$ref": "./common.schema.json#/$defs/nonEmptyString"
                },
                "description": {
                  "$ref": "./common.schema.json#/$defs/nonEmptyString"
                },
                "owner": {
                  "$ref": "./common.schema.json#/$defs/nonEmptyString"
                },
                "risk_tier": {
                  "$ref": "./common.schema.json#/$defs/riskTier"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "active",
                    "deprecated"
                  ]
                },
                "superseded_by": {
                  "$ref": "./common.schema.json#/$defs/id"
                },
                "orthogonal_tags": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "trinitarian": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "functional": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "layer": {
                      "type": "string"
                    },
                    "autonomy_tier": {
                      "type": "string"
                    }
                  }
                },
                "floor_scope": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "id",
                "name",
                "version",
                "description",
                "owner",
                "risk_tier",
                "status",
                "orthogonal_tags",
                "floor_scope"
              ]
            }
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "skills"
        ]
      }
    }
  },
  "required": [
    "version",
    "packages"
  ]
}
