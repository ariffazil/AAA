{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifOS/agent-card/v2.3.0",
  "title": "arifOS Agent Card v2.3.0 — Registry Truth Binding",
  "description": "Extends v2.2.0 with registry_receipt_hash binding. Cards without a valid registry_receipt_hash are INADMISSIBLE as evidence-bearing surface. Source code (git HEAD) is the single primary truth; registry and MCP surface are derived views.",
  "version": "2.3.0",
  "supersedes": "arifOS/agent-card/v2.2.0",
  "forged_at": "2026-07-16T20:00:00Z",
  "seal_ref": "VAULT999/SUPERSESSION-2026-07-16-CARD-GENESIS.json",

  "type": "object",
  "additionalProperties": true,

  "properties": {
    "$schema": {
      "type": "string",
      "const": "arifOS/agent-card/v2.3.0",
      "description": "Schema identifier — all federation agent cards MUST use this value"
    },
    "schemaVersion": {
      "type": "string",
      "const": "2.3.0",
      "description": "Explicit schema version"
    },

    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "protocolVersion": { "type": "string", "description": "A2A protocol version" },
    "url": { "type": "string", "format": "uri" },
    "runtime": { "type": "string", "description": "Runtime engine name" },
    "runtime_port": { "type": "number", "description": "Runtime port" },
    "documentationUrl": { "type": "string", "format": "uri" },

    "principal_agent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["llm", "architect", "agent", "human", "institution", "earth", "void", "liar", "unknown"] },
        "category": { "type": "string" },
        "principle_origin": { "type": "string" }
      },
      "required": ["type"]
    },

    "provider": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "organization": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },

    "capabilities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "streaming": { "type": "boolean" },
        "pushNotifications": { "type": "boolean" },
        "stateTransitionHistory": { "type": "boolean" },
        "tool_calling": { "type": "boolean" },
        "mcp_native": { "type": "boolean" },
        "file_read": { "type": "boolean" },
        "file_write": { "type": "boolean" },
        "shell_exec": { "type": "boolean" },
        "subagent_spawn": { "type": "boolean" }
      }
    },

    "securitySchemes": { "type": "object", "additionalProperties": true },
    "security": { "type": "array", "items": { "type": "object", "additionalProperties": true } },

    "defaultInputModes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "defaultOutputModes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },

    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "floor_scope": { "type": "array", "items": { "type": "string" } },
          "approval_policy": { "type": "string" }
        }
      }
    },

    "registry_receipt_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{16,}$",
      "description": "MANDATORY (v2.3.0). SHA256 of the source code snapshot used to enumerate this card's tools. Cards WITHOUT this field are INADMISSIBLE. Consumers must verify this hash against the live source before trusting tool names."
    },
    "registry_snapshot_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the source snapshot was taken"
    },
    "registry_source": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Which layers were probed: source_enumeration, mcp_tools_list, registry_api"
    },
    "registry_tool_count": {
      "type": "object",
      "description": "Tool counts per layer for drift detection",
      "properties": {
        "source": { "type": "integer" },
        "registry": { "type": "integer" },
        "card": { "type": "integer" }
      }
    },
    "registry_drift": {
      "type": "object",
      "description": "Drift between layers. Empty arrays = no drift.",
      "properties": {
        "source_to_registry": { "type": "array", "items": { "type": "string" }, "description": "Tools in source but not in live registry" },
        "registry_to_source": { "type": "array", "items": { "type": "string" }, "description": "Tools in live registry but not in source" },
        "source_to_registry_drift_pct": { "type": "number", "description": "Percentage match between source and registry" }
      }
    },
    "admissible": {
      "type": "boolean",
      "description": "false if source→registry drift detected. Consumers must NOT trust tool names on inadmissible cards."
    },

    "tier": { "type": "string", "enum": ["FI", "AGI", "ASI", "APEX"] },
    "role": { "type": "string" },
    "class": { "type": "string" },
    "mcp_servers": { "type": "array", "items": { "type": "string" } },
    "subAgentPolicy": { "type": "object", "additionalProperties": true },
    "autonomy_tiers": { "type": "object", "additionalProperties": true },

    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "canDo": { "type": "array", "items": { "type": "string" } },
        "cannotDo": { "type": "array", "items": { "type": "string" } }
      }
    },

    "charter": { "type": "object", "additionalProperties": true },

    "mcp_surface": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["exposed", "consumed"] },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": { "type": "string" },
              "tool_count": { "type": "integer" },
              "tools": { "type": "array", "items": { "type": "string" } },
              "key_lanes": { "type": "array", "items": { "type": "string" } },
              "version": { "type": "string" },
              "registry_receipt_hash": { "type": "string" }
            }
          }
        }
      }
    },

    "governance_profile": {
      "type": "object",
      "properties": {
        "constitutional_floors": { "type": "array", "items": { "type": "string", "pattern": "^F[0-9]{1,2}$" } },
        "verdict_authority": { "type": "string" },
        "self_approval_forbidden": { "type": "boolean" },
        "subagent_default_hold": { "type": "string" },
        "warga_boundary": { "type": "boolean" },
        "vault": { "type": "string", "enum": ["VAULT999"] },
        "functional_class": { "type": "string" },
        "mesh_role": { "type": "string" },
        "requires_human_for": { "type": "array", "items": { "type": "string" } }
      }
    },

    "status": {
      "type": "string",
      "enum": ["live", "spec", "installed", "not_connected", "retired"]
    },

    "model": { "type": "string" },
    "host": { "type": "string" },
    "transport": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },

  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "name",
    "description",
    "version",
    "protocolVersion",
    "url",
    "provider",
    "capabilities",
    "defaultInputModes",
    "defaultOutputModes",
    "skills",
    "registry_receipt_hash",
    "registry_snapshot_at",
    "admissible"
  ],

  "validation_invariants": [
    {
      "id": "INV-001",
      "description": "Only arifOS may set self_approval_forbidden: false",
      "rule": "if id !== 'arifos' then governance_profile.self_approval_forbidden === true"
    },
    {
      "id": "INV-005",
      "description": "Cards without registry_receipt_hash are INADMISSIBLE",
      "rule": "registry_receipt_hash MUST match pattern ^sha256:[a-f0-9]{16,}$. Missing = INVALID.",
      "severity": "error"
    },
    {
      "id": "INV-006",
      "description": "admissible=false means consumers must NOT trust tool names",
      "rule": "if admissible === false then consumers must read live registry, not card tools list",
      "severity": "warn"
    },
    {
      "id": "INV-007",
      "description": "source_to_registry drift > 0 tools = admissible must be false",
      "rule": "if registry_drift.source_to_registry.length > 0 then admissible === false",
      "severity": "error"
    }
  ],

  "migration": {
    "from": "arifOS/agent-card/v2.2.0",
    "strategy": "additive — all existing fields preserved",
    "additions": [
      "registry_receipt_hash (REQUIRED) — SHA256 of source snapshot",
      "registry_snapshot_at (REQUIRED) — ISO-8601 timestamp",
      "registry_source — which layers were probed",
      "registry_tool_count — per-layer tool counts",
      "registry_drift — drift arrays between layers",
      "admissible (REQUIRED) — false if drift detected"
    ]
  }
}
