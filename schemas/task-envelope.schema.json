{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/task-envelope.schema.json",
  "title": "AAA Unified Task Envelope",
  "description": "Canonical federation object for all routed tasks, results, and telemetry. Every agent, router, memory consumer, and audit ledger understands one envelope.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique task identifier."
    },
    "parent_task_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "For sub-tasks. Null if root."
    },
    "session_id": {
      "type": "string",
      "description": "Federation session identifier."
    },
    "intent": {
      "type": "string",
      "description": "Human-readable summary of what the task aims to do."
    },
    "request_text": {
      "type": "string",
      "description": "Raw user or agent request."
    },
    "request_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of the normalized request."
    },
    "agent_selected": {
      "type": "string",
      "description": "Canonical agent ID assigned to execute this task."
    },
    "tool_candidates": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tools shortlisted by the capability index."
    },
    "tools_used": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tools actually invoked during execution."
    },
    "state": {
      "type": "string",
      "enum": ["submitted", "working", "input_required", "completed", "failed", "held", "sealed"],
      "description": "Current lifecycle state."
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "constitutional_verdict": {
      "type": "string",
      "enum": ["SEAL", "PARTIAL", "SABAR", "HOLD", "VOID", "PENDING"],
      "description": "arifOS 888_JUDGE verdict. PENDING if not yet adjudicated."
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" },
          "checksum": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "learning_points": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "learning_type": { "type": "string", "enum": ["tool", "routing", "memory", "constitutional", "sandbox"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "promotion_state": { "type": "string", "enum": ["ephemeral", "candidate", "validated", "sealed"] },
          "contradiction_keys": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "timestamps": {
      "type": "object",
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "required": ["created_at"]
    },
    "metadata": {
      "type": "object",
      "description": "Extra context: repo, branch, files touched, agent version."
    }
  },
  "required": [
    "task_id",
    "session_id",
    "intent",
    "request_hash",
    "agent_selected",
    "state",
    "risk_tier",
    "constitutional_verdict",
    "timestamps"
  ]
}
