#!/usr/bin/env python3
"""
openclaw-agentic: autonomous_probe.py  (v2.1.0 — merged)
==========================================================

Lightweight health probe for the OpenClaw gateway + federation.

Tier-0: pure read-only. No LLM, no session, no agent turn. < 2s typical runtime.

Probes (10):
  1. Gateway 18789 /health                  RED if !200, YELLOW if "degraded"
  2. Webhook listener 8787 (TCP connect)    RED if closed
  3. arifOS MCP 8088 /health                RED if !200, YELLOW if drifted
  4. GEOX MCP 8081 /health                  RED if !200
  5. GEOX MCP 18081 /health (slim stub)     YELLOW if down (informational, not gate)
  6. WEALTH MCP 18082 /health               RED if !200
  7. WELL MCP 18083 /health                 RED if !200
  8. A-FORGE 7071 /health                   YELLOW if down
  9. Telegram getWebhookInfo                RED if pending>20, YELLOW if 502/504 in last_err
 10. /root disk %                           RED ≥85, YELLOW ≥75

v2.1.0 (2026-06-08) — Recursive merge pass:
  KEPT from v2 (OpenClaw parallel session 4fc1c1b5):
    + 10-probe coverage (incl A-FORGE 7071, GEOX_slim 18081)
    + Heartbeat at /run/openclaw_probe.heartbeat for watchdog verification
    + arifOS drift detection (YELLOW if runtime≠build)
    + Telegram 502/504 = YELLOW (transient webhook) not RED
    + Log to /var/log/arifos/openclaw-probe.log (logrotate handles rotation)
    + 6s hard wall budget (probe never stalls the cron)
    + Compact daily-note: 1 line on GREEN, 4 lines on YELLOW/RED
  ADDED from v1.1.0 (Hermes pass):
    + Alert dedup: state/alert_state.json, 30-min cooldown per red signature
    + Direct Telegram API POST via urllib (no curl subprocess, no CLI roundtrip)
    + CLI flags: --quiet (suppress stdout, cron mode), --no-state (force post),
      --diagnose (human-readable), --once (default)
    + PROBE_OK_v2.1.0 stdout signature (so scheduler failures attribute correctly)
    + Signature in log_line for postmortem

DITEMPA BUKAN DIBERI — Forged, not given.
"""
from __future__ import annotations
import argparse
import json
import socket
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone, timedelta
from pathlib import Path

# ---- constants ----
PROBE_VERSION = "v2.1.0"
PROBE_SIG = f"PROBE_OK_{PROBE_VERSION}"

OPENCLAW_CFG = Path("/root/.openclaw/openclaw.json")
NOTE_DIR = Path("/root/.openclaw/memory")
LOG_FILE = Path("/var/log/arifos/openclaw-probe.log")
HEARTBEAT_FILE = Path("/run/openclaw_probe.heartbeat")
PROBE_START_FILE = Path("/run/openclaw_probe.laststart")
STATE_DIR = Path("/root/.openclaw/workspace/skills/openclaw-agentic/state")
STATE_FILE = STATE_DIR / "alert_state.json"

GATEWAY_PORT = 18789
WEBHOOK_PORT = 8787
AFORGE_PORT = 7071
MCP_PORTS = {
    "arifOS": 8088,
    "GEOX": 8081,
    "GEOX_slim_18081": 18081,   # informational only — not a gate
    "WEALTH": 18082,
    "WELL": 18083,
}
ARIF_TG_ID = "267378578"

# Thresholds
ALERT_COOLDOWN_SEC = 1800       # 30 min between alerts for the SAME red signature
DISK_YELLOW_PCT = 75
DISK_RED_PCT = 85
TG_PENDING_RED = 20
TG_LASTERR_RED_SEC = 3600

# Per-probe timeouts (seconds)
TCP_TIMEOUT = 1.2
HTTP_TIMEOUT = 1.5
TELEGRAM_TIMEOUT = 2.5
DISK_TIMEOUT = 1.5
HARD_BUDGET_S = 6.0

MYT = timezone(timedelta(hours=8))


# ---- helpers ----
def now_utc() -> datetime:
    return datetime.now(timezone.utc)


def now_myt_str() -> str:
    return now_utc().astimezone(MYT).strftime("%Y-%m-%d %H:%M:%S MYT")


def tcp_open(host: str, port: int, timeout: float = TCP_TIMEOUT) -> bool:
    try:
        with socket.create_connection((host, port), timeout=timeout):
            return True
    except (OSError, socket.timeout):
        return False


def http_get(url: str, timeout: float = HTTP_TIMEOUT) -> tuple[bool, str]:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as r:
            body = r.read().decode("utf-8", errors="replace")
            return (200 <= r.status < 400, body)
    except (urllib.error.URLError, urllib.error.HTTPError, OSError, TimeoutError) as e:
        return (False, str(e)[:200])


def probe_telegram() -> tuple[str, int | None, str]:
    try:
        cfg = json.loads(OPENCLAW_CFG.read_text())
        token = cfg["channels"]["telegram"]["botToken"]
    except (OSError, KeyError, json.JSONDecodeError) as e:
        return ("RED", None, f"config: {e}")
    ok, body = http_get(
        f"https://api.telegram.org/bot{token}/getWebhookInfo",
        timeout=TELEGRAM_TIMEOUT,
    )
    if not ok:
        return ("RED", None, body)
    try:
        d = json.loads(body)
        result = d.get("result", {})
        pending = int(result.get("pending_update_count", -1))
        last_err = (result.get("last_error_message", "") or "").replace('"', "'").replace("\n", " ")[:80]
        last_err_date = int(result.get("last_error_date", 0) or 0)
    except (json.JSONDecodeError, ValueError, TypeError) as e:
        return ("RED", None, f"parse: {str(e)[:60]}")
    if "502" in last_err or "504" in last_err:
        return ("YELLOW", pending, f"webhook_{last_err[:40]}")
    if pending > TG_PENDING_RED:
        return ("RED", pending, f"pending={pending} last_err={last_err[:40] or 'ok'}")
    if last_err_date and (time.time() - last_err_date) < TG_LASTERR_RED_SEC:
        return ("YELLOW", pending, f"recent_err pending={pending}")
    return ("GREEN", pending, f"pending={pending} last_err={last_err[:40] or 'ok'}")


def probe_disk() -> tuple[str, int, str]:
    try:
        out = subprocess.check_output(["df", "-P", "/root"], text=True, timeout=DISK_TIMEOUT)
        parts = out.strip().split("\n")[1].split()
        pct = int(parts[4].rstrip("%"))
        if pct >= DISK_RED_PCT:
            return ("RED", pct, f"{pct}% on /root")
        if pct >= DISK_YELLOW_PCT:
            return ("YELLOW", pct, f"{pct}% on /root")
        return ("GREEN", pct, f"{pct}% on /root")
    except (subprocess.CalledProcessError, IndexError, ValueError, OSError, TimeoutError) as e:
        return ("RED", -1, f"df failed: {e}")


def probe_arifos_quality(body: str) -> tuple[bool, str]:
    """arifOS port may be open but drifted. YELLOW if status != 'healthy' or runtime≠build."""
    if not body:
        return (False, "empty body")
    try:
        d = json.loads(body)
        status = d.get("status", "unknown")
        identity = d.get("identity_hash", {}).get("b3_prefix", "")[:8]
        runtime_matches = d.get("runtime_matches_build")
        if status == "healthy":
            if runtime_matches is False:
                return (True, f"drift runtime≠build identity={identity}")
            return (True, f"healthy identity={identity}")
        return (False, f"status={status} identity={identity}")
    except (json.JSONDecodeError, ValueError, TypeError):
        return (True, "tcp_open status_unknown")


def in_business_hours() -> bool:
    h = datetime.now(MYT).hour
    return 7 <= h <= 23


# ---- alert dedup ----
def load_alert_state() -> dict:
    try:
        return json.loads(STATE_FILE.read_text())
    except (OSError, json.JSONDecodeError):
        return {"last_alerts": {}}


def save_alert_state(state: dict) -> None:
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        STATE_FILE.write_text(json.dumps(state, indent=2))
    except OSError as e:
        sys.stderr.write(f"[probe] state write failed: {e}\n")


def should_alert(red_sig: str, state: dict, now: float) -> bool:
    last = state.get("last_alerts", {}).get(red_sig, 0)
    return (now - last) > ALERT_COOLDOWN_SEC


def mark_alerted(red_sig: str, state: dict, now: float) -> None:
    state.setdefault("last_alerts", {})[red_sig] = now


# ---- direct Telegram post (urllib, no subprocess) ----
def post_to_telegram(message: str) -> bool:
    """POST directly to Telegram Bot API. No CLI / no curl subprocess.
    Returns True on HTTP 2xx, False otherwise. Never raises."""
    try:
        token = json.loads(OPENCLAW_CFG.read_text())["channels"]["telegram"]["botToken"]
    except (OSError, KeyError, json.JSONDecodeError) as e:
        sys.stderr.write(f"[probe] token read failed: {e}\n")
        return False
    url = f"https://api.telegram.org/bot{token}/sendMessage"
    payload = json.dumps({
        "chat_id": ARIF_TG_ID,
        "text": message[:3500],
        "disable_web_page_preview": True,
    }).encode("utf-8")
    req = urllib.request.Request(
        url, data=payload, method="POST",
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=4.0) as r:
            ok = 200 <= r.status < 300
            if not ok:
                sys.stderr.write(f"[probe] tg status={r.status}\n")
            return ok
    except (urllib.error.URLError, urllib.error.HTTPError, OSError, TimeoutError) as e:
        sys.stderr.write(f"[probe] tg post failed: {e}\n")
        return False


# ---- log ----
def append_log(line: str) -> None:
    try:
        LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
        with LOG_FILE.open("a", encoding="utf-8") as f:
            f.write(line + "\n")
    except OSError:
        pass


# ---- main probe ----
def run_probe(args) -> int:
    started = time.time()
    stamp = now_utc().isoformat(timespec="seconds")
    try:
        PROBE_START_FILE.write_text(str(int(started)))
    except OSError:
        pass

    results: dict[str, dict] = {}
    red_count = 0
    yellow_count = 0

    # 1. Gateway /health
    ok, body = http_get(f"http://127.0.0.1:{GATEWAY_PORT}/health")
    degraded = "degraded" in body.lower() if ok else False
    if not ok:
        results["gateway_18789"] = {"status": "RED", "detail": body[:120]}
        red_count += 1
    elif degraded:
        results["gateway_18789"] = {"status": "YELLOW", "detail": body[:120]}
        yellow_count += 1
    else:
        results["gateway_18789"] = {"status": "GREEN", "detail": body[:120]}

    # 2. Webhook listener (TCP)
    open_ = tcp_open("127.0.0.1", WEBHOOK_PORT)
    results["webhook_8787"] = {
        "status": "GREEN" if open_ else "RED",
        "detail": "open" if open_ else "closed",
    }
    if not open_:
        red_count += 1

    # 3. arifOS MCP — YELLOW if drifted
    ok, body = http_get("http://127.0.0.1:8088/health")
    if not ok:
        results["mcp_arifOS_8088"] = {"status": "RED", "detail": body[:120]}
        red_count += 1
    else:
        is_yellow, detail = probe_arifos_quality(body)
        if is_yellow and ("drift" in detail or "status=unknown" in detail):
            results["mcp_arifOS_8088"] = {"status": "YELLOW", "detail": detail}
            yellow_count += 1
        else:
            results["mcp_arifOS_8088"] = {"status": "GREEN", "detail": detail}

    # 4-7. Other MCPs (GEOX_slim_18081 is informational)
    for name, port in MCP_PORTS.items():
        if name == "arifOS":
            continue
        ok, body = http_get(f"http://127.0.0.1:{port}/health")
        is_informational = name == "GEOX_slim_18081"
        if not ok:
            if is_informational:
                results[f"mcp_{name}"] = {"status": "YELLOW", "detail": "stub unreachable (informational)"}
                yellow_count += 1
            else:
                results[f"mcp_{name}"] = {"status": "RED", "detail": body[:120]}
                red_count += 1
        else:
            results[f"mcp_{name}"] = {"status": "GREEN", "detail": body[:120]}

    # 8. A-FORGE
    ok, body = http_get(f"http://127.0.0.1:{AFORGE_PORT}/health")
    results["aforge_7071"] = {
        "status": "GREEN" if ok else "YELLOW",
        "detail": body[:80] if ok else f"down: {body[:80]}",
    }
    if not ok:
        yellow_count += 1

    # 9. Telegram
    tg_status, tg_pending, tg_detail = probe_telegram()
    results["telegram"] = {"status": tg_status, "detail": tg_detail}
    if tg_status == "RED":
        red_count += 1
    elif tg_status == "YELLOW":
        yellow_count += 1

    # 10. Disk
    disk_status, disk_pct, disk_detail = probe_disk()
    results["disk"] = {"status": disk_status, "detail": disk_detail}
    if disk_status == "RED":
        red_count += 1
    elif disk_status == "YELLOW":
        yellow_count += 1

    runtime_ms = int((time.time() - started) * 1000)
    if runtime_ms > HARD_BUDGET_S * 1000:
        sys.stderr.write(f"[probe] over hard budget: {runtime_ms}ms > {HARD_BUDGET_S*1000}ms\n")

    summary = {
        "sig": PROBE_SIG,
        "stamp": stamp,
        "myt": now_myt_str(),
        "version": PROBE_VERSION,
        "runtime_ms": runtime_ms,
        "red": red_count,
        "yellow": yellow_count,
        "results": results,
    }

    # Heartbeat for watchdog (atomic write)
    try:
        HEARTBEAT_FILE.write_text(str(int(started)))
    except OSError:
        pass

    # Print signature line + JSON to stdout. Signature FIRST so scheduler failures
    # can distinguish "probe ran and was healthy" from "probe didn't run at all".
    if not args.quiet:
        print(f"{PROBE_SIG} {json.dumps(summary, ensure_ascii=False)}")

    # Log line: single line per run, all probes inline
    log_line = f"{stamp} {now_myt_str()} v={PROBE_VERSION} sig={PROBE_SIG} rt={runtime_ms}ms red={red_count} yel={yellow_count} | "
    log_line += " ".join(f"{k}={v['status']}" for k, v in results.items())
    append_log(log_line)

    # Daily memory note: 1 line on GREEN, 4 lines on YELLOW/RED
    myt_today = now_utc().astimezone(MYT).strftime("%Y-%m-%d")
    note = NOTE_DIR / f"{myt_today}.md"
    try:
        NOTE_DIR.mkdir(parents=True, exist_ok=True)
        with note.open("a", encoding="utf-8") as f:
            if red_count == 0 and yellow_count == 0:
                f.write(f"\n## openclaw probe {PROBE_VERSION} — {stamp} — GREEN ({runtime_ms}ms)\n")
            else:
                f.write(f"\n## openclaw probe {PROBE_VERSION} — {stamp} — red={red_count} yel={yellow_count} ({runtime_ms}ms)\n")
                for k, v in results.items():
                    if v["status"] != "GREEN":
                        f.write(f"  - {k:25s} {v['status']:6s} {v['detail'][:80]}\n")
    except OSError:
        pass

    # Alert logic with dedup
    if red_count > 0 and not args.quiet:
        red_items = [f"{k}={v['status']}" for k, v in results.items() if v["status"] == "RED"]
        red_sig = "|".join(sorted(red_items))
        now = time.time()

        if not in_business_hours():
            try:
                with note.open("a", encoding="utf-8") as f:
                    f.write(f"  > alert suppressed: outside business hours (07-23 MYT)\n")
            except OSError:
                pass
        else:
            if args.no_state:
                msg = f"🫀 openclaw probe RED ({red_count}) [forced]: {', '.join(red_items[:5])}"
                post_to_telegram(msg)
            else:
                state = load_alert_state()
                if should_alert(red_sig, state, now):
                    msg = f"🫀 openclaw probe RED ({red_count}): {', '.join(red_items[:5])}"
                    if post_to_telegram(msg):
                        mark_alerted(red_sig, state, now)
                        save_alert_state(state)
                else:
                    try:
                        with note.open("a", encoding="utf-8") as f:
                            f.write(f"  > alert dedup: {red_sig[:60]} (cooldown {ALERT_COOLDOWN_SEC}s)\n")
                    except OSError:
                        pass

    return 0  # always exit 0 — cron is a probe, not a gate


def main() -> int:
    ap = argparse.ArgumentParser(
        description=f"OpenClaw autonomous health probe {PROBE_VERSION}",
        epilog=f"Signature: {PROBE_SIG} {{...}}",
    )
    ap.add_argument("--once", action="store_true", default=True,
                    help="Run a single probe cycle and exit (default)")
    ap.add_argument("--quiet", action="store_true",
                    help="Suppress stdout (cron mode; only log to file + daily note)")
    ap.add_argument("--no-state", action="store_true",
                    help="Skip alert dedup; force post on RED even if in cooldown")
    ap.add_argument("--diagnose", action="store_true",
                    help="Run probe + print human-readable summary + force post on RED")
    args = ap.parse_args()

    rc = run_probe(args)

    if args.diagnose:
        print(f"[diagnose] {PROBE_SIG} finished, rc={rc}", file=sys.stderr)
        try:
            hb_age = time.time() - int(HEARTBEAT_FILE.read_text())
            print(f"[diagnose] heartbeat age: {int(hb_age)}s", file=sys.stderr)
        except (OSError, ValueError):
            print(f"[diagnose] no heartbeat found", file=sys.stderr)

    return rc


if __name__ == "__main__":
    sys.exit(main())
