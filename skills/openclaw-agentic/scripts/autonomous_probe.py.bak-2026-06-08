#!/usr/bin/env python3
"""
openclaw-agentic: autonomous_probe.py
======================================

Lightweight health probe for the OpenClaw gateway + federation.

Tier 1 — safe, read-only. No restarts, no writes outside the daily note + state.

v1.1.0 (2026-06-08) — Recursive improvement pass:
  - Alert dedup with state file (no more 5-min spam of same RED)
  - Direct Telegram API POST (no openclaw CLI roundtrip — 15s → <1s)
  - Log rotation: 2MB cap, keep last 3 files (.1 .2 .3) gzipped
  - CLI flags: --once (default), --quiet (suppress post), --no-state (skip dedup)
  - Probe signature line in stdout so scheduler failures attribute correctly
  - Probe reasons explicitly: "RED" vs "YELLOW" thresholds documented
  - --diagnose mode for one-shot deep probe (logs to file + prints)

Probes (8):
  1. Gateway 18789 /health                  — RED if !200, YELLOW if "degraded"
  2. Webhook listener 8787 (TCP connect)    — RED if closed
  3. arifOS MCP 8088 /health                — RED if !200
  4. GEOX MCP 8081 /health                  — RED if !200
  5. WEALTH MCP 18082 /health               — RED if !200
  6. WELL MCP 18083 /health                 — RED if !200
  7. Telegram pending_update_count + last   — RED if pending>20 OR last_err<1h
  8. /root disk pressure                    — RED ≥85%, YELLOW ≥75%

Output: single line JSON to stdout (probe signature: PROBE_OK_v1.1.0:...)
Post to Telegram ONLY if any probe is RED, NOT in cooldown, AND in business hours.

DITEMPA BUKAN DIBERI — Forged, not given.
"""
from __future__ import annotations
import argparse
import gzip
import json
import os
import socket
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime, timezone, timedelta
from pathlib import Path

# ───────────────────────── constants ─────────────────────────
PROBE_VERSION = "1.1.0"
PROBE_SIG = f"PROBE_OK_v{PROBE_VERSION}"  # signature line; scheduler watches for this

OPENCLAW_CFG = Path("/root/.openclaw/openclaw.json")
NOTE_DIR = Path("/root/.openclaw/memory")
STATE_DIR = Path("/root/.openclaw/workspace/skills/openclaw-agentic/state")
STATE_FILE = STATE_DIR / "alert_state.json"
LOG_PATH = Path("/root/.openclaw/logs/autonomous_probe.log")

GATEWAY_PORT = 18789
WEBHOOK_PORT = 8787
MCP_PORTS = {
    "arifOS": 8088,
    "GEOX": 8081,
    "WEALTH": 18082,
    "WELL": 18083,
}
ARIF_TG_ID = "267378578"

# Thresholds
ALERT_COOLDOWN_SEC = 1800       # 30 min between alerts for the SAME red signature
LOG_MAX_BYTES = 2 * 1024 * 1024  # 2 MB
LOG_KEEP_FILES = 3
TG_PENDING_RED = 20
TG_LASTERR_RED_SEC = 3600
DISK_YELLOW_PCT = 75
DISK_RED_PCT = 85

MYT = timezone(timedelta(hours=8))


# ───────────────────────── helpers ─────────────────────────
def tcp_open(host: str, port: int, timeout: float = 1.5) -> bool:
    try:
        with socket.create_connection((host, port), timeout=timeout):
            return True
    except (OSError, socket.timeout):
        return False


def http_get(url: str, timeout: float = 2.0) -> tuple[bool, str]:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as r:
            body = r.read().decode("utf-8", errors="replace")
            return (200 <= r.status < 400, body)
    except (urllib.error.URLError, urllib.error.HTTPError, OSError, TimeoutError) as e:
        return (False, str(e)[:200])


def probe_telegram() -> tuple[bool, int | None, str]:
    try:
        cfg = json.loads(OPENCLAW_CFG.read_text())
        token = cfg["channels"]["telegram"]["botToken"]
    except (OSError, KeyError, json.JSONDecodeError) as e:
        return (False, None, f"config read failed: {e}")
    ok, body = http_get(f"https://api.telegram.org/bot{token}/getWebhookInfo", timeout=3.0)
    if not ok:
        return (False, None, body)
    try:
        d = json.loads(body)
        result = d.get("result", {})
        pending = int(result.get("pending_update_count", -1))
        last_err = result.get("last_error_message", "") or ""
        try:
            last_err_date = int(result.get("last_error_date", 0) or 0)
        except (ValueError, TypeError):
            last_err_date = 0
        is_red = pending > TG_PENDING_RED or (last_err_date and (time.time() - last_err_date) < TG_LASTERR_RED_SEC)
        last_err_safe = last_err.replace('"', "'").replace("\n", " ")[:80]
        return (not is_red, pending, last_err_safe or "ok")
    except (json.JSONDecodeError, ValueError, TypeError) as e:
        return (False, None, f"parse: {str(e)[:60]}")


def probe_disk() -> tuple[bool, int, str]:
    try:
        out = subprocess.check_output(["df", "-P", "/root"], text=True, timeout=2.0)
        parts = out.strip().split("\n")[1].split()
        pct = int(parts[4].rstrip("%"))
        return (pct < DISK_RED_PCT, pct, f"{pct}% on /root")
    except (subprocess.CalledProcessError, IndexError, ValueError, OSError) as e:
        return (False, -1, f"df failed: {e}")


def in_business_hours() -> bool:
    h = datetime.now(MYT).hour
    return 7 <= h <= 23


# ───────────────────────── alert dedup ─────────────────────────
def load_alert_state() -> dict:
    try:
        return json.loads(STATE_FILE.read_text())
    except (OSError, json.JSONDecodeError):
        return {"last_alerts": {}}


def save_alert_state(state: dict) -> None:
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        STATE_FILE.write_text(json.dumps(state, indent=2))
    except OSError as e:
        sys.stderr.write(f"[probe] state write failed: {e}\n")


def should_alert(red_sig: str, state: dict, now: float) -> bool:
    """True if (a) we never alerted on this sig, or (b) cooldown expired."""
    last = state.get("last_alerts", {}).get(red_sig, 0)
    return (now - last) > ALERT_COOLDOWN_SEC


def mark_alerted(red_sig: str, state: dict, now: float) -> None:
    state.setdefault("last_alerts", {})[red_sig] = now


# ───────────────────────── direct Telegram post ─────────────────────────
def post_telegram_direct(message: str) -> bool:
    """POST directly to Telegram Bot API. No openclaw CLI roundtrip.
    Returns True on HTTP 2xx, False otherwise. Never raises."""
    try:
        token = json.loads(OPENCLAW_CFG.read_text())["channels"]["telegram"]["botToken"]
    except (OSError, KeyError, json.JSONDecodeError) as e:
        sys.stderr.write(f"[probe] token read failed: {e}\n")
        return False
    url = f"https://api.telegram.org/bot{token}/sendMessage"
    payload = json.dumps({
        "chat_id": ARIF_TG_ID,
        "text": message,
        "disable_web_page_preview": True,
    }).encode("utf-8")
    req = urllib.request.Request(
        url, data=payload, method="POST",
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=4.0) as r:
            ok = 200 <= r.status < 300
            if not ok:
                sys.stderr.write(f"[probe] tg status={r.status}\n")
            return ok
    except (urllib.error.URLError, urllib.error.HTTPError, OSError, TimeoutError) as e:
        sys.stderr.write(f"[probe] tg post failed: {e}\n")
        return False


# ───────────────────────── log rotation ─────────────────────────
def rotate_log_if_needed(path: Path) -> None:
    """If path > LOG_MAX_BYTES, rotate: .3 → delete, .2 → .3.gz, .1 → .2.gz, current → .1.gz."""
    try:
        if not path.exists() or path.stat().st_size < LOG_MAX_BYTES:
            return
        # oldest first
        oldest = path.with_suffix(path.suffix + f".{LOG_KEEP_FILES}")
        if oldest.exists():
            oldest.unlink()
        for i in range(LOG_KEEP_FILES - 1, 0, -1):
            src = path.with_suffix(path.suffix + f".{i}")
            dst = path.with_suffix(path.suffix + f".{i + 1}")
            if src.exists():
                # gzipped move
                with src.open("rb") as f_in, gzip.open(str(dst) + ".gz", "wb") as f_out:
                    shutil.copyfileobj(f_in, f_out)
                src.unlink()
        # current → .1
        if path.exists():
            gz_dst = path.with_suffix(path.suffix + ".1.gz")
            with path.open("rb") as f_in, gzip.open(str(gz_dst), "wb") as f_out:
                shutil.copyfileobj(f_in, f_out)
            path.unlink()
        sys.stderr.write(f"[probe] log rotated at {datetime.now(MYT).isoformat()}\n")
    except OSError as e:
        sys.stderr.write(f"[probe] log rotate failed: {e}\n")


# ───────────────────────── main ─────────────────────────
def run_probe(args) -> int:
    rotate_log_if_needed(LOG_PATH)

    results: dict[str, dict] = {}
    red_count = 0
    yellow_count = 0

    # 1. Gateway /health
    ok, body = http_get(f"http://127.0.0.1:{GATEWAY_PORT}/health", timeout=2.0)
    is_yellow = ok and "degraded" in body.lower()
    is_red = not ok
    results["gateway_18789"] = {
        "status": "RED" if is_red else ("YELLOW" if is_yellow else "GREEN"),
        "detail": body[:120],
    }
    if is_red:
        red_count += 1
    elif is_yellow:
        yellow_count += 1

    # 2. Webhook listener (TCP only)
    open_ = tcp_open("127.0.0.1", WEBHOOK_PORT, 1.0)
    results["webhook_8787"] = {
        "status": "GREEN" if open_ else "RED",
        "detail": "open" if open_ else "closed",
    }
    if not open_:
        red_count += 1

    # 3-6. MCP organs
    for name, port in MCP_PORTS.items():
        ok, body = http_get(f"http://127.0.0.1:{port}/health", timeout=2.0)
        results[f"mcp_{name}_{port}"] = {
            "status": "GREEN" if ok else "RED",
            "detail": body[:120] if ok else "no response",
        }
        if not ok:
            red_count += 1

    # 7. Telegram
    tg_ok, tg_pending, tg_detail = probe_telegram()
    results["telegram"] = {
        "status": "GREEN" if tg_ok else "RED",
        "detail": f"pending={tg_pending} last_err={tg_detail[:60]}",
    }
    if not tg_ok:
        red_count += 1

    # 8. Disk
    disk_ok, disk_pct, disk_detail = probe_disk()
    if not disk_ok:
        results["disk"] = {"status": "RED", "detail": disk_detail}
        red_count += 1
    elif disk_pct > DISK_YELLOW_PCT:
        results["disk"] = {"status": "YELLOW", "detail": disk_detail}
        yellow_count += 1
    else:
        results["disk"] = {"status": "GREEN", "detail": disk_detail}

    stamp = datetime.now(timezone.utc).isoformat(timespec="seconds")
    summary = {
        "sig": PROBE_SIG,
        "stamp": stamp,
        "myt": datetime.now(MYT).strftime("%Y-%m-%d %H:%M:%S MYT"),
        "red": red_count,
        "yellow": yellow_count,
        "results": results,
    }

    # Always print ONE signature line first — this is what the scheduler should watch for.
    # If we crash before this, the scheduler sees a "no signature" = distinguishable from a probe that ran.
    if not args.quiet:
        print(f"{PROBE_SIG} {json.dumps(summary, ensure_ascii=False)}")

    # Append to daily note (use MYT date so the note matches Arif's calendar day)
    myt_today = datetime.now(MYT).strftime("%Y-%m-%d")
    note = NOTE_DIR / f"{myt_today}.md"
    try:
        NOTE_DIR.mkdir(parents=True, exist_ok=True)
        with note.open("a", encoding="utf-8") as f:
            f.write(f"\n## openclaw autonomous_probe v{PROBE_VERSION} — {stamp}\n")
            for k, v in results.items():
                f.write(f"  - {k:25s} {v['status']:6s} {v['detail'][:80]}\n")
            f.write(f"  --- red={red_count} yellow={yellow_count}\n")
    except OSError:
        pass  # notes are best-effort

    # Alert dedup + post
    if red_count > 0 and not args.quiet:
        red_items = [f"{k}={v['status']}" for k, v in results.items() if v["status"] == "RED"]
        red_sig = "|".join(sorted(red_items))  # stable signature for dedup
        now = time.time()

        if not in_business_hours():
            # Outside hours: log the suppression explicitly so the audit trail shows we made a call
            try:
                with note.open("a", encoding="utf-8") as f:
                    f.write(f"  > alert suppressed: outside business hours (07-23 MYT)\n")
            except OSError:
                pass
        else:
            if args.no_state:
                # forced: send regardless
                msg = f"🫀 openclaw probe RED ({red_count}) [forced]: {', '.join(red_items[:5])}"
                post_telegram_direct(msg)
            else:
                state = load_alert_state()
                if should_alert(red_sig, state, now):
                    msg = f"🫀 openclaw probe RED ({red_count}): {', '.join(red_items[:5])}"
                    if post_telegram_direct(msg):
                        mark_alerted(red_sig, state, now)
                        save_alert_state(state)
                else:
                    # In cooldown — log it
                    try:
                        with note.open("a", encoding="utf-8") as f:
                            f.write(f"  > alert dedup: {red_sig[:60]} (cooldown {ALERT_COOLDOWN_SEC}s)\n")
                    except OSError:
                        pass

    return 0  # always exit 0 — cron is a probe, not a gate


def main() -> int:
    ap = argparse.ArgumentParser(
        description=f"OpenClaw autonomous health probe v{PROBE_VERSION}",
        epilog=f"Signature line printed to stdout: {PROBE_SIG} {{...}}",
    )
    ap.add_argument("--once", action="store_true", default=True,
                    help="Run a single probe cycle and exit (default)")
    ap.add_argument("--quiet", action="store_true",
                    help="Suppress stdout (only log to file + daily note)")
    ap.add_argument("--no-state", action="store_true",
                    help="Skip alert dedup; force post on RED even if in cooldown")
    ap.add_argument("--diagnose", action="store_true",
                    help="Run probe + print human-readable summary + force post on RED")
    args = ap.parse_args()

    rc = run_probe(args)

    if args.diagnose and not args.quiet:
        # Re-run a quick summary line for human readability
        try:
            cfg = json.loads(OPENCLAW_CFG.read_text())
            tg = cfg["channels"]["telegram"]["botToken"][:8]
            print(f"[diagnose] openclaw.json readable, tg_token={tg}…", file=sys.stderr)
        except Exception as e:
            print(f"[diagnose] config read failed: {e}", file=sys.stderr)

    return rc


if __name__ == "__main__":
    sys.exit(main())
