    "opencode-go": {
      "provider": "OpenCode",
      "product": "OpenCode Go (proxy)",
      "auth": "API key",
      "description": "Multi-model proxy \u2014 routes to underlying providers",
      "models": {
        "claude-sonnet-5": {
          "tool_call": true,
          "reasoning": true,
          "context_window": 200000,
          "federation_tools": {
            "available": true
