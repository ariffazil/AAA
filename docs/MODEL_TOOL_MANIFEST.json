          "context_window": 128000,
          "federation_tools": {
            "available": true
          }
        },
        "gemini-3.1-pro": {
          "tool_call": true,
          "reasoning": true,
          "context_window": 1000000,
          "federation_tools": {
            "available": true
          }
        },
        "deepseek-v4-pro": {
          "tool_call": true,
          "reasoning": true,
          "context_window": 1000000,
          "federation_tools": {
            "available": true
          }
        }
      }
    }
  },
  "routing_rules": {
    "web_research": {
      "primary": "azure-foundry (via azure_call.py --search)",
      "fallback": "qwen-token/qwen3.7-max (OpenCode provider)",
      "reason": "Built-in web_search, fastest latency"
    },
    "computation": {
      "primary": "azure-foundry (via azure_call.py --tools)",
      "fallback": "qwen-token/qwen3.7-max (OpenCode provider)",
      "reason": "Built-in code_interpreter"
    },
    "federation_ops": {
      "primary": "tokenplan-mimo/mimo-v2.5-pro",
      "fallback": "qwen-token/glm-5.2",
      "reason": "323+ federation tools via function calling"
    },
    "deep_reasoning": {
      "primary": "qwen-token/deepseek-v4-pro",
      "fallback": "opencode-go/claude-opus-4-8",
      "reason": "1M context, deep reasoning"
    },
    "code_generation": {
      "primary": "qwen-token/kimi-k2.7-code",
      "fallback": "tokenplan-mimo/mimo-v2.5-pro",
      "reason": "Code-specialized model"
    },
    "enterprise_search": {
      "primary": "m365-copilot (external \u2014 Arif laptop only)",
      "fallback": "qwen-token/qwen3.7-max (web search proxy)",
      "reason": "Only runtime with M365 access",
      "note": "M365 not on af-forge. Use web search as fallback."
    },
    "office_artifacts": {
      "primary": "m365-copilot",
      "fallback": null,
      "reason": "docx/pdf/slides/xlsx skills only available here"
    },
    "image_generation": {
      "primary": "qwen-image/qwen-image-2.0",
      "fallback": "m365-copilot/image_gen",
      "reason": "Dedicated image model"
    },
    "geox": {
      "primary": "tokenplan-mimo/mimo-v2.5-pro",
      "fallback": "qwen-token/glm-5.2",
      "reason": "Federation tools (geox_*) available via function calling"
    },
    "well": {
      "primary": "tokenplan-mimo/mimo-v2.5-pro",
      "fallback": "qwen-token/glm-5.2",
      "reason": "Federation tools (well_*) available via function calling"
    },
    "github": {
      "primary": "tokenplan-mimo/mimo-v2.5-pro",
      "fallback": "qwen-token/glm-5.2",
      "reason": "Federation tools (forge_github_*) available via function calling"
    },
    "browser": {
      "primary": "tokenplan-mimo/mimo-v2.5-pro",
      "fallback": "qwen-token/glm-5.2",
      "reason": "Federation tools (forge_browser_*, chrome-devtools_*) available"
    },
    "infrastructure": {
      "primary": "tokenplan-mimo/mimo-v2.5-pro",
      "fallback": "qwen-token/glm-5.2",
      "reason": "Federation tools (forge_shell, forge_docker, hostinger-vps_*) available"
    }
  },
  "external_runtimes": {
    "m365-copilot": {
      "provider": "Microsoft",
