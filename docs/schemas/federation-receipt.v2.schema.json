{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arifos.arif-fazil.com/schemas/federation-receipt/v2.0.0",
  "title": "Federation Receipt Envelope — v2.0.0",
  "description": "Immutable consequence receipt. Terminates a federation invocation chain.",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "invocation_id",
    "trace_id",
    "session_id",
    "actor_id",
    "source_organ",
    "verdict",
    "payload_hash",
    "chain_hash",
    "sealed_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0.0" },
    "receipt_id": { "type": "string", "description": "Unique receipt identifier. VAULT999 memoryId." },
    "invocation_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "session_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "source_organ": { "type": "string" },
    "destination_organ": { "type": "string" },
    "capability_id": { "type": "string" },
    "verdict": { "type": "string", "enum": ["SEAL", "HOLD", "VOID", "SABAR"], "description": "Constitutional verdict." },
    "epistemic_tag": { "type": "string", "enum": ["OBSERVED", "COMPUTED"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "payload_hash": { "type": "string", "description": "SHA-256 of the sealed content." },
    "chain_hash": { "type": "string", "description": "VAULT999 chain hash linking to prior receipt." },
    "prev_chain_hash": { "type": "string", "description": "Previous receipt's chain_hash for continuity." },
    "sealed_at": { "type": "string", "format": "date-time" },
    "replay_verification": { "type": "string", "description": "Command to replay and verify this receipt." },
    "source_release": { "type": "string" },
    "source_manifest_hash": { "type": "string" }
  },
  "additionalProperties": false
}
