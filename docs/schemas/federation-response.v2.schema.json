{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arifos.arif-fazil.com/schemas/federation-response/v2.0.0",
  "title": "Federation Response Envelope — v2.0.0",
  "description": "Cross-organ response envelope. Every capability result MUST carry this envelope.",
  "type": "object",
  "required": [
    "schema_version",
    "invocation_id",
    "trace_id",
    "hop_index",
    "session_id",
    "actor_id",
    "source_organ",
    "destination_organ",
    "status",
    "epistemic_tag",
    "issued_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0.0" },
    "invocation_id": { "type": "string", "description": "Echo of the request invocation_id." },
    "parent_invocation_id": { "type": ["string", "null"] },
    "trace_id": { "type": "string" },
    "hop_index": { "type": "integer" },
    "session_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "source_organ": { "type": "string", "enum": ["arifOS", "AAA", "A-FORGE", "GEOX", "WEALTH", "WELL", "VAULT999", "HERMES"] },
    "destination_organ": { "type": "string", "enum": ["arifOS", "AAA", "A-FORGE", "GEOX", "WEALTH", "WELL", "VAULT999", "HERMES"] },
    "status": { "type": "string", "enum": ["SUCCESS", "PARTIAL", "DEGRADED", "FAILED"], "description": "Execution status." },
    "epistemic_tag": { "type": "string", "enum": ["OBSERVED", "COMPUTED", "ESTIMATE", "INFERRED", "UNKNOWN"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "payload_hash": { "type": "string", "description": "SHA-256 of the result payload." },
    "payload": { "type": "object", "description": "Capability result data." },
    "receipt_ref": { "type": "string", "description": "VAULT999 receipt reference if sealed." },
    "chain_hash": { "type": "string", "description": "VAULT999 chain hash for replay verification." },
    "warnings": { "type": "array", "items": { "type": "string" }, "description": "Non-fatal warnings." },
    "degraded_notes": { "type": "array", "items": { "type": "string" }, "description": "If status=DEGRADED, what was degraded." },
    "issued_at": { "type": "string", "format": "date-time" },
    "elapsed_ms": { "type": "integer", "description": "Processing time in milliseconds." }
  },
  "additionalProperties": false
}
