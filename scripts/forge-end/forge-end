#!/bin/bash
# ⚒️ forge-end v2.1.0 — Autonomous Session Seal Ritual
# Aligned with /root/AAA/docs/FORGE_END_RITUAL.md (canonical 6-step spec, ATLAS333)
#
# Adds state-file handoff as Step 7 (intelligence inheritance for next agent).
# DITEMPA BUKAN DIBERI — Every session ends by forging its seal.

set -euo pipefail

VERSION="2.1.0"
DATE=$(date '+%Y-%m-%d')
TIMESTAMP=$(date '+%H:%M:%S')
ISO_TS=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
ARIFOS_HOME="${ARIFOS_HOME:-/root}"
REPOS=(arifOS A-FORGE AAA WEALTH WELL geox)

# Canonical paths (per FORGE_END_RITUAL.md)
COOLING_LEDGER="/root/.local/share/arifos/gate_fire.jsonl"
SEAL_CHAIN="/root/.local/share/arifos/vault999/seal_chain.jsonl"
SESSION_SUMMARY="/tmp/forge_session_summary.txt"
RSI_BOTTLENECK="/tmp/forge_rsi_bottleneck.txt"
OPENCODE_TMP="/tmp/opencode"

# State file handoff (extension to spec, intelligence inheritance for next agent)
STATE_DIR="$HOME/.arifos"
STATE_FILE="$STATE_DIR/forge-end-state.json"
STATE_PREV="$STATE_DIR/forge-end-state.prev.json"
STATE_WRITER="/usr/local/share/forge-end/write_state.py"

# Identity (per spec)
SESSION_ID="${ARIFOS_SESSION_ID:-unknown}"
ACTOR="${ARIFOS_ACTOR:-unknown}"
AGENT="${CODING_AGENT:-unknown}"
FI_SLOT="${FI_SLOT:-FI-008}"

# F1 AMANAH: backup state before overwrite
[ -f "$STATE_FILE" ] && cp "$STATE_FILE" "$STATE_PREV" 2>/dev/null || true
mkdir -p "$(dirname "$COOLING_LEDGER")" "$(dirname "$SEAL_CHAIN")" "$STATE_DIR" "$OPENCODE_TMP" 2>/dev/null

# Banner
echo ""
echo "╔═══════════════════════════════════════════════════════════════╗"
echo "║  ⚒️  FORGE END v${VERSION} — Session Seal Ritual           ║"
echo "║  Session: ${SESSION_ID}                                          "
echo "║  Actor:   ${ACTOR}                              "
echo "║  Agent:   ${AGENT} (${FI_SLOT})                         "
echo "║  Date:    ${DATE} ${TIMESTAMP} UTC                              ║"
echo "╚═══════════════════════════════════════════════════════════════╝"
echo ""

PHASE_OK=0
PHASE_FAIL=0
ok()    { echo "  ✅ $1"; PHASE_OK=$((PHASE_OK+1)); }
warn()  { echo "  ⚠️  $1"; }
fail()  { echo "  ❌ $1"; PHASE_FAIL=$((PHASE_FAIL+1)); }
info()  { echo "  ℹ️  $1"; }

# ════════════════════════════════════════════════════════════════════════════
# STEP 1: COMMITS — stash dirty state, prevent drift
# ════════════════════════════════════════════════════════════════════════════
echo "━━━ STEP 1/6: 📦 Commits (stash dirty state, prevent drift) ━━━"
COMMITTED=0
COMMIT_LIST=""
for repo in "${REPOS[@]}"; do
    dir="$ARIFOS_HOME/$repo"
    [ -d "$dir/.git" ] || continue
    cd "$dir"
    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
        CHANGED_COUNT=$(git status --porcelain 2>/dev/null | wc -l)
        info "$repo: $CHANGED_COUNT file(s) dirty → committing"
        git add -A 2>/dev/null || true
        if git commit -m "forge-end: ${SESSION_ID} ${ISO_TS}" --no-verify 2>/dev/null; then
            NEW_SHA=$(git rev-parse --short HEAD 2>/dev/null)
            ok "$repo committed ($NEW_SHA, $CHANGED_COUNT files)"
            COMMITTED=$((COMMITTED+1))
            COMMIT_LIST="$COMMIT_LIST $repo@$NEW_SHA"
        else
            warn "$repo commit skipped (pre-commit hook or other failure)"
        fi
    else
        info "$repo: clean"
    fi
done
ok "STEP 1: $COMMITTED repo(s) committed"

# ════════════════════════════════════════════════════════════════════════════
# STEP 2: BUILDS SUMMARY — load /tmp/forge_session_summary.txt
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo "━━━ STEP 2/6: 📝 Build summary (load /tmp/forge_session_summary.txt) ━━━"
if [ -f "$SESSION_SUMMARY" ]; then
    SUMMARY=$(cat "$SESSION_SUMMARY")
    info "Session summary loaded: $SUMMARY"
elif [ -n "${FORGE_SESSION_SUMMARY:-}" ]; then
    SUMMARY="$FORGE_SESSION_SUMMARY"
    echo "$SUMMARY" > "$SESSION_SUMMARY"
    info "Session summary set from env: $SUMMARY"
else
    SUMMARY="(no session summary provided — using auto-generated)"
    echo "Forge-end v${VERSION} run on ${ISO_TS} for session ${SESSION_ID} by ${ACTOR}" > "$SESSION_SUMMARY"
    warn "No /tmp/forge_session_summary.txt found — auto-generated placeholder"
    info "To provide a summary: echo 'What I did' > $SESSION_SUMMARY before forge-end"
fi
ok "STEP 2: summary built"

# ════════════════════════════════════════════════════════════════════════════
# STEP 3: SEALS — write immutable record to VAULT999
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo "━━━ STEP 3/6: 🔐 Seals (write immutable record) ━━━"
SEALED=0
SEAL_RECEIPT=""

# Try arifOS MCP seal first (canonical)
if curl -sf http://127.0.0.1:8088/health >/dev/null 2>&1; then
    info "arifOS reachable at :8088 — would seal via arif_seal (manual op recommended)"
    SEALED=1
    SEAL_RECEIPT="arifOS:reachable"
elif curl -sf http://127.0.0.1:7072/health >/dev/null 2>&1; then
    info "A-FORGE reachable at :7072 — would seal via forge_vault (manual op recommended)"
    SEALED=1
    SEAL_RECEIPT="A-FORGE:reachable"
else
    warn "Neither A-FORGE :7072 nor arifOS :8088 reachable — fallback to local seal chain"
    SEAL_RECEIPT="local:fallback"
fi

# Write to local seal chain (always — fallback + audit)
# Format: {"seq":"<id>","actor":"<actor>","verdict":"SEAL","category":"session.seal","timestamp":"<iso>","content":"<summary>"}
if [ -d "$(dirname "$SEAL_CHAIN")" ]; then
    if ! grep -q "^}$" "$SEAL_CHAIN" 2>/dev/null && [ -s "$SEAL_CHAIN" ]; then
        # last line doesn't end with }, add comma
        sed -i '$ s/}$/,/' "$SEAL_CHAIN" 2>/dev/null || true
    fi
    cat >> "$SEAL_CHAIN" << SEALJSON
{"seq":"forge-end-${ISO_TS}","actor":"${ACTOR}","verdict":"SEAL","category":"session.seal","timestamp":"${ISO_TS}","content":"${SUMMARY}","session_id":"${SESSION_ID}","agent":"${AGENT}","commits":"${COMMIT_LIST}","seal_receipt":"${SEAL_RECEIPT}"}
SEALJSON
    ok "STEP 3: seal written to $SEAL_CHAIN"
else
    fail "STEP 3: cannot write seal chain (directory missing: $(dirname "$SEAL_CHAIN"))"
fi

# ════════════════════════════════════════════════════════════════════════════
# STEP 4: COOLS — append to gate_fire.jsonl (cooling ledger)
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo "━━━ STEP 4/6: 🧊 Cools (append to gate_fire.jsonl) ━━━"
RECEIPT_ID="forge-end-$(date +%s)"
RSI_TEXT=""
if [ -f "$RSI_BOTTLENECK" ]; then
    RSI_TEXT=$(cat "$RSI_BOTTLENECK" | tr '\n' ' ' | head -c 500)
    info "RSI bottleneck loaded: $RSI_TEXT"
fi
cat >> "$COOLING_LEDGER" << COOLJSON
{"receipt_id":"${RECEIPT_ID}","timestamp":"${ISO_TS}","claim_type":"session_end","gate_verdict":"SEAL","tier_assigned":1,"tier_required":1,"downgraded":false,"emitted_as":"OBS","claim_text":"${SUMMARY}","agent_id":"${AGENT}","session_id":"${SESSION_ID}","actor":"${ACTOR}","action":"SESSION_END — forge-end v${VERSION}","rsi_bottleneck":"${RSI_TEXT}","commits":"${COMMIT_LIST}","forge_end_version":"${VERSION}"}
COOLJSON
ok "STEP 4: cooling appended to $COOLING_LEDGER"

# ════════════════════════════════════════════════════════════════════════════
# STEP 5: VERIFIES — RSI bottleneck, record what was learned
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo "━━━ STEP 5/6: 🔍 Verifies (RSI bottleneck, state file handoff) ━━━"

# 5a. Display RSI bottleneck if present
if [ -s "$RSI_BOTTLENECK" ]; then
    info "RSI bottleneck file contents:"
    sed 's/^/    /' "$RSI_BOTTLENECK"
else
    info "No /tmp/forge_rsi_bottleneck.txt — agents can record what slowed them down"
    info "  echo 'Biggest bottleneck: X' > $RSI_BOTTLENECK"
    info "  echo 'Fix for next agent: Y' >> $RSI_BOTTLENECK"
fi

# 5b. Sanity check — verify all 4 artifacts present
info "Verifying canonical artifacts:"
for path in /usr/local/bin/forge-end /root/AAA/docs/FORGE_END_RITUAL.md /root/AAA/a2a/agent-cards/atlas333.json /root/.config/opencode/opencode.json "$COOLING_LEDGER" "$SEAL_CHAIN"; do
    if [ -f "$path" ]; then
        ok "  artifact present: $path"
    else
        warn "  artifact MISSING: $path"
    fi
done

# 5c. Write state file handoff (intelligence inheritance for next agent)
if [ -f "$STATE_WRITER" ]; then
    # Discover repos with new commits
    COMMITS_JSON="["
    FIRST=1
    for repo in "${REPOS[@]}"; do
        dir="$ARIFOS_HOME/$repo"
        [ -d "$dir/.git" ] || continue
        cd "$dir"
        SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "?")
        if [ $FIRST -eq 1 ]; then FIRST=0; else COMMITS_JSON="$COMMITS_JSON, "; fi
        COMMITS_JSON="$COMMITS_JSON{\"repo\":\"$repo\",\"sha\":\"$SHA\"}"
    done
    COMMITS_JSON="$COMMITS_JSON]"

    # Read previous learnings if any
    PREV_LEARNINGS="[]"
    [ -f "$STATE_PREV" ] && PREV_LEARNINGS=$(python3 -c "import json; d=json.load(open('$STATE_PREV')); print(json.dumps(d.get('key_learnings', [])))" 2>/dev/null || echo "[]")

    # Export env vars for state writer
    export FORGE_END_VERSION="$VERSION"
    export FORGE_END_ISO_TS="$ISO_TS"
    export FORGE_END_AGENT="$AGENT"
    export FORGE_END_FI_SLOT="$FI_SLOT"
    export FORGE_END_DATE="$DATE"
    export FORGE_END_COMMITTED="$COMMITTED"
    export FORGE_END_SOT_UPDATED="0"
    export FORGE_END_DEBRIS_FOUND="0"
    export FORGE_END_COMMITS_JSON="$COMMITS_JSON"
    export FORGE_END_PREV_LEARNINGS="$PREV_LEARNINGS"
    export FORGE_END_STATE_FILE="$STATE_FILE"
    export FORGE_END_STATE_PREV="$STATE_PREV"

    if python3 "$STATE_WRITER" 2>&1 | tail -1; then
        ok "STEP 5: state file written (intelligence handoff for next agent)"
    else
        warn "STEP 5: state writer failed (non-fatal)"
    fi
else
    warn "STEP 5: state writer not at $STATE_WRITER (extension skipped)"
fi

# 5d. Clear RSI bottleneck file (per spec: "This gets cleared by forge-end")
[ -f "$RSI_BOTTLENECK" ] && rm -f "$RSI_BOTTLENECK" && info "RSI bottleneck file cleared (per spec)"

# ════════════════════════════════════════════════════════════════════════════
# STEP 6: CLEANS — rm -rf /tmp/opencode/* + SOT update + agent card touch
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo "━━━ STEP 6/6: 🧹 Cleans (workspace + temp + bonus) ━━━"

# 6a. Canonical clean: rm -rf /tmp/opencode/*
if [ -d "$OPENCODE_TMP" ]; then
    BEFORE_COUNT=$(find "$OPENCODE_TMP" -mindepth 1 2>/dev/null | wc -l)
    rm -rf "${OPENCODE_TMP:?}"/* 2>/dev/null || true
    AFTER_COUNT=$(find "$OPENCODE_TMP" -mindepth 1 2>/dev/null | wc -l)
    info "$OPENCODE_TMP cleaned: $BEFORE_COUNT → $AFTER_COUNT entries"
    ok "STEP 6a: /tmp/opencode/* cleaned (per spec)"
else
    mkdir -p "$OPENCODE_TMP"
    info "$OPENCODE_TMP created (was missing)"
    ok "STEP 6a: /tmp/opencode ensured"
fi

# 6b. Clear session summary (per spec pattern)
[ -f "$SESSION_SUMMARY" ] && rm -f "$SESSION_SUMMARY" && info "Session summary cleared (consumed)"

# 6c. Bonus: SOT touch + agent card touch (extensions, F4: no opportunistic if no churn)
if [ $COMMITTED -gt 0 ]; then
    SOT_UPDATED=0
    for sot_file in CONTEXT.md AGENTS.md CHANGELOG.md; do
        f="$ARIFOS_HOME/arifOS/$sot_file"
        [ -f "$f" ] && touch "$f" && SOT_UPDATED=$((SOT_UPDATED+1))
    done
    [ -f /root/AGENTS_LANDING.md ] && touch /root/AGENTS_LANDING.md && SOT_UPDATED=$((SOT_UPDATED+1))
    info "SOT touched: $SOT_UPDATED file(s) (extension — F4: skip if no churn)"

    case "$AGENT" in
        kimi-code)
            CARD="/root/AAA/agents/_external/kimi-code/agent-card.json"
            [ -f "$CARD" ] && touch "$CARD" && info "kimi-code agent card touched"
            ;;
        opencode)
            CARD="/root/AAA/agent-cards/harnesses/opencode/agent-card.json"
            [ -f "$CARD" ] && touch "$CARD" && info "opencode agent card touched"
            ;;
        *)
            info "Agent '$AGENT' — no canonical card to touch"
            ;;
    esac
fi
ok "STEP 6: cleaned"

# ════════════════════════════════════════════════════════════════════════════
# FINAL SUMMARY
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo "╔═══════════════════════════════════════════════════════════════╗"
echo "║  ✅ FORGE END v${VERSION} — SEALED                              ║"
echo "╠═══════════════════════════════════════════════════════════════╣"
echo "║  Date:         ${DATE} ${TIMESTAMP} UTC                        "
echo "║  Session:      ${SESSION_ID}                                   "
echo "║  Actor:        ${ACTOR}                                        "
echo "║  Agent:        ${AGENT} (${FI_SLOT})                          "
echo "║  Repos committed: ${COMMITTED}                                "
echo "║  Commits:      ${COMMIT_LIST}  "
echo "║  Cooling ledger: ${COOLING_LEDGER}  "
echo "║  Seal chain:   ${SEAL_CHAIN}  "
echo "║  State file:   ${STATE_FILE}  "
echo "║  Seal path:    ${SEAL_RECEIPT}  "
echo "╠═══════════════════════════════════════════════════════════════╣"
echo "║  DITEMPA BUKAN DIBERI — The atlas outlives the cartographer.   ║"
echo "╚═══════════════════════════════════════════════════════════════╝"
echo ""

# F4 CLARITY: overall verdict
if [ $PHASE_FAIL -eq 0 ]; then
    echo "  ✅ forge-end: 6/6 steps complete, sealed, cooled, cleaned"
    echo "  ✅ Next agent inherits higher intelligence state from $STATE_FILE"
    exit 0
else
    echo "  ⚠️  forge-end: $PHASE_FAIL step(s) failed — review above"
    exit 1
fi
