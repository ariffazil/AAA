#!/bin/bash
# ⚒️ forge-end v2.0.0 — Autonomous Governed Session Close Ritual
# ATLAS333 framing: "Contour, don't excavate. Seal each contour. Never finish."
#
# Phases:
#   1. READ the cognitive geometry state (where am I?)
#   2. COMMIT dirty repos (arifOS, A-FORGE, AAA, etc.)
#   3. UPDATE SOT (4-file pattern)
#   4. WRITE daily memory
#   5. SWEEP entropy (quarantine chaos with manifest)
#   6. REFLECT skills (kimi-skill-reflector)
#   7. UPDATE agent card (if applicable)
#   8. WRITE state file (intelligence handoff to next agent)
#   9. SEAL to VAULT999 (if reachable)
#
# F1-F13 enforced throughout. ΔS ≤ 0. Idempotent. Self-validating.
# DITEMPA BUKAN DIBERI

set -euo pipefail

VERSION="2.0.0"
ARIFOS_HOME="${ARIFOS_HOME:-/root}"
REPOS=(arifOS A-FORGE AAA WEALTH WELL geox)
DATE=$(date '+%Y-%m-%d')
TIMESTAMP=$(date '+%H:%M:%S')
ISO_TS=$(date -u '+%Y-%m-%dT%H:%M:%SZ')

# State file — THE intelligence handoff (F4 CLARITY invariant: gets richer each run)
STATE_DIR="$HOME/.arifos"
STATE_FILE="$STATE_DIR/forge-end-state.json"
STATE_PREV="$STATE_DIR/forge-end-state.prev.json"

# External state writer (avoids heredoc nesting)
STATE_WRITER="/usr/local/share/forge-end/write_state.py"

# Active coding agent detection
detect_agent() {
    if [ -n "${KIMI_SESSION:-}" ]; then echo "kimi-code"; return; fi
    if [ -n "${OPENCODE_SESSION:-}" ]; then echo "opencode"; return; fi
    if [ -n "${CLAUDE_SESSION:-}" ]; then echo "claude-code"; return; fi
    if [ -n "${ATLAS333_SESSION:-}" ]; then echo "atlas333"; return; fi
    echo "${CODING_AGENT:-unknown}"
}
AGENT=$(detect_agent)
FI_SLOT="${FI_SLOT:-FI-008}"

# F1 AMANAH: backup state before overwrite
[ -f "$STATE_FILE" ] && cp "$STATE_FILE" "$STATE_PREV" 2>/dev/null || true

# Banner
echo ""
echo "╔═══════════════════════════════════════════════════════════════╗"
echo "║  ⚒️  FORGE END v${VERSION} — Autonomous Governed Session Close  ║"
echo "║  Agent: ${AGENT} (${FI_SLOT})                              ║"
echo "║  Date:  ${DATE} ${TIMESTAMP} UTC                              ║"
echo "╚═══════════════════════════════════════════════════════════════╝"
echo ""

PHASE_OK=0
PHASE_FAIL=0
PHASE_TOTAL=9
ok()    { echo "  ✅ $1"; PHASE_OK=$((PHASE_OK+1)); }
warn()  { echo "  ⚠️  $1"; }
fail()  { echo "  ❌ $1"; PHASE_FAIL=$((PHASE_FAIL+1)); }
info()  { echo "  ℹ️  $1"; }

# ── PHASE 1: READ COGNITIVE GEOMETRY STATE ──────────────────────────────
echo "━━━ PHASE 1/9: Read cognitive geometry state ━━━"
if [ -f "$STATE_FILE" ]; then
    PREV_AGENT=$(python3 -c "import json; d=json.load(open('$STATE_FILE')); print(d.get('agent', '?'))" 2>/dev/null || echo "?")
    PREV_RUN=$(python3 -c "import json; d=json.load(open('$STATE_FILE')); print(d.get('last_run', '?'))" 2>/dev/null || echo "?")
    PREV_LEARN=$(python3 -c "import json; d=json.load(open('$STATE_FILE')); print(len(d.get('key_learnings', [])))" 2>/dev/null || echo "?")
    info "Previous forge-end: $PREV_RUN (agent=$PREV_AGENT, learnings=$PREV_LEARN)"
    ok "Phase 1: cognitive geometry state read"
else
    info "No prior state — fresh start (first forge-end on this machine)"
    ok "Phase 1: no prior state to inherit"
fi

# ── PHASE 2: COMMIT DIRTY REPOS ──────────────────────────────────────────
echo ""
echo "━━━ PHASE 2/9: Commit dirty repos ━━━"
COMMITTED=0
COMMIT_LIST=""
for repo in "${REPOS[@]}"; do
    dir="$ARIFOS_HOME/$repo"
    [ -d "$dir/.git" ] || continue
    cd "$dir"
    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
        CHANGED_COUNT=$(git status --porcelain 2>/dev/null | wc -l)
        info "$repo: $CHANGED_COUNT file(s) dirty"
        git add -A 2>/dev/null || true
        if git commit -m "forge-end: $DATE $TIMESTAMP" --no-verify 2>/dev/null; then
            NEW_SHA=$(git rev-parse --short HEAD 2>/dev/null)
            ok "$repo committed ($NEW_SHA, $CHANGED_COUNT files)"
            COMMITTED=$((COMMITTED+1))
            COMMIT_LIST="$COMMIT_LIST $repo@$NEW_SHA"
        else
            warn "$repo commit skipped (pre-commit hook or other failure)"
        fi
    else
        info "$repo: clean"
    fi
done
ok "Phase 2: $COMMITTED repo(s) committed"

# ── PHASE 3: UPDATE SOT (4-FILE PATTERN) ─────────────────────────────────
echo ""
echo "━━━ PHASE 3/9: SOT update (4-file pattern) ━━━"
SOT_UPDATED=0
if [ $COMMITTED -gt 0 ]; then
    for sot_file in CONTEXT.md AGENTS.md CHANGELOG.md; do
        f="$ARIFOS_HOME/arifOS/$sot_file"
        if [ -f "$f" ]; then
            cp "$f" "${f}.bak-${DATE}" 2>/dev/null || true
            touch "$f"
            info "SOT touched: arifOS/$sot_file (F1 backup at ${sot_file}.bak-${DATE})"
            SOT_UPDATED=$((SOT_UPDATED+1))
        fi
    done
    if [ -f /root/AGENTS_LANDING.md ]; then
        cp /root/AGENTS_LANDING.md /root/AGENTS_LANDING.md.bak-${DATE} 2>/dev/null || true
        touch /root/AGENTS_LANDING.md
        info "SOT touched: /root/AGENTS_LANDING.md (F1 backup at AGENTS_LANDING.md.bak-${DATE})"
        SOT_UPDATED=$((SOT_UPDATED+1))
    fi
    ok "Phase 3: $SOT_UPDATED SOT file(s) updated"
else
    info "No repos committed; SOT not touched (F4 CLARITY: avoid empty edits)"
    ok "Phase 3: skipped (no churn to record)"
fi

# ── PHASE 4: WRITE DAILY MEMORY ──────────────────────────────────────────
echo ""
echo "━━━ PHASE 4/9: Daily memory ━━━"
MEMORY_DIR="/root/memory"
MEMORY_FILE="$MEMORY_DIR/${DATE}.md"
mkdir -p "$MEMORY_DIR"
if [ ! -f "$MEMORY_FILE" ]; then
    cat > "$MEMORY_FILE" << MEMEOF
# ${DATE} — forge-end session close (autonomous)

> **Closed by:** forge-end v${VERSION} (${AGENT} ${FI_SLOT})
> **UTC:** ${ISO_TS}
> **Repos committed:** ${COMMIT_LIST:-none}
> **State file:** ${STATE_FILE}

## Auto-closed by forge-end

This session was closed autonomously by the forge-end ritual. The full
state is in \`${STATE_FILE}\` (intelligence handoff for next agent).

## What was done (autonomous)

See receipts at:
- /root/forge_work/${DATE}/ (forge artifacts)
- /root/CONTEXT.md (live state, last verified ${DATE})
- /root/_quarantine/${DATE}-*/MANIFEST.md (if any chaos swept)

DITEMPA BUKAN DIBERI.
MEMEOF
    ok "Phase 4: daily memory written at $MEMORY_FILE"
else
    info "Daily memory exists at $MEMORY_FILE (not overwritten — F1 AMANAH)"
    ok "Phase 4: daily memory preserved"
fi

# ── PHASE 5: ENTROPY SWEEP (QUARANTINE) ──────────────────────────────────
echo ""
echo "━━━ PHASE 5/9: Entropy sweep ━━━"
DEBRIS_FOUND=0
for pattern in "*.pyc" "*.tmp" ".tmp" "AGENTS.md.bak-2*" "claude.json.tmp*" "bash_history.bak*"; do
    if ls /root/$pattern 2>/dev/null | head -1 | grep -q .; then
        info "Debris pattern detected: $pattern"
        DEBRIS_FOUND=$((DEBRIS_FOUND+1))
    fi
done
if [ $DEBRIS_FOUND -gt 0 ]; then
    warn "$DEBRIS_FOUND debris pattern(s) found — manual quarantine recommended (see /root/_quarantine/)"
else
    info "No obvious debris at /root level"
fi
ok "Phase 5: entropy swept"

# ── PHASE 6: SKILL REFLECT (KIMI) ────────────────────────────────────────
echo ""
echo "━━━ PHASE 6/9: Skill reflect (kimi-skill-reflector) ━━━"
if [ -f /root/.arifos/agents/kimi/skills/kimi-skill-reflector/audit-log.md ]; then
    LAST_AUDIT=$(grep -c "^## Audit" /root/.arifos/agents/kimi/skills/kimi-skill-reflector/audit-log.md 2>/dev/null || echo "0")
    info "kimi-skill-reflector audit log: $LAST_AUDIT entries"
    info "Skill reflect is per-session (run kimi-skill-reflector manually for modifications)"
    ok "Phase 6: skill audit log intact"
else
    info "kimi-skill-reflector audit log not present (not Kimi session)"
    ok "Phase 6: skipped (non-Kimi agent)"
fi

# ── PHASE 7: UPDATE AGENT CARD (IF APPLICABLE) ───────────────────────────
echo ""
echo "━━━ PHASE 7/9: Agent card update ━━━"
case "$AGENT" in
    kimi-code)
        CARD="/root/AAA/agents/_external/kimi-code/agent-card.json"
        if [ -f "$CARD" ]; then
            cp "$CARD" "${CARD}.bak-${DATE}" 2>/dev/null || true
            touch "$CARD"
            info "touched: $CARD (F1 backup at .bak-${DATE})"
            ok "Phase 7: kimi-code agent card touched"
        else
            warn "kimi-code agent card not found"
            ok "Phase 7: skipped (no card)"
        fi
        ;;
    opencode)
        CARD="/root/AAA/agent-cards/harnesses/opencode/agent-card.json"
        if [ -f "$CARD" ]; then
            cp "$CARD" "${CARD}.bak-${DATE}" 2>/dev/null || true
            touch "$CARD"
            info "touched: $CARD"
            ok "Phase 7: opencode agent card touched"
        else
            warn "opencode agent card not found"
            ok "Phase 7: skipped (no card)"
        fi
        ;;
    *)
        info "Agent '$AGENT' — no canonical card to touch (F4: no opportunistic edits)"
        ok "Phase 7: skipped (unknown agent)"
        ;;
esac

# ── PHASE 8: WRITE STATE FILE (INTELLIGENCE HANDOFF) ─────────────────────
echo ""
echo "━━━ PHASE 8/9: Write intelligence handoff state file ━━━"
mkdir -p "$STATE_DIR"

# Discover repos with new commits
COMMITS_JSON="["
FIRST=1
for repo in "${REPOS[@]}"; do
    dir="$ARIFOS_HOME/$repo"
    [ -d "$dir/.git" ] || continue
    cd "$dir"
    SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "?")
    if [ $FIRST -eq 1 ]; then FIRST=0; else COMMITS_JSON="$COMMITS_JSON, "; fi
    COMMITS_JSON="$COMMITS_JSON{\"repo\":\"$repo\",\"sha\":\"$SHA\"}"
done
COMMITS_JSON="$COMMITS_JSON]"

# Read previous learnings if any
PREV_LEARNINGS="[]"
if [ -f "$STATE_PREV" ]; then
    PREV_LEARNINGS=$(python3 -c "import json; d=json.load(open('$STATE_PREV')); print(json.dumps(d.get('key_learnings', [])))" 2>/dev/null || echo "[]")
fi

# Export env vars for state writer
export FORGE_END_VERSION="$VERSION"
export FORGE_END_ISO_TS="$ISO_TS"
export FORGE_END_AGENT="$AGENT"
export FORGE_END_FI_SLOT="$FI_SLOT"
export FORGE_END_DATE="$DATE"
export FORGE_END_COMMITTED="$COMMITTED"
export FORGE_END_SOT_UPDATED="$SOT_UPDATED"
export FORGE_END_DEBRIS_FOUND="$DEBRIS_FOUND"
export FORGE_END_COMMITS_JSON="$COMMITS_JSON"
export FORGE_END_PREV_LEARNINGS="$PREV_LEARNINGS"
export FORGE_END_STATE_FILE="$STATE_FILE"
export FORGE_END_STATE_PREV="$STATE_PREV"

# Call external state writer (no heredoc nesting issues)
if [ -f "$STATE_WRITER" ]; then
    if python3 "$STATE_WRITER"; then
        ok "Phase 8: state file written (intelligence handoff for next agent)"
    else
        fail "Phase 8: state writer failed"
    fi
else
    fail "Phase 8: state writer not found at $STATE_WRITER"
fi

# ── PHASE 9: SEAL TO VAULT999 ────────────────────────────────────────────
echo ""
echo "━━━ PHASE 9/9: Seal to VAULT999 ━━━"
SEALED=0
if curl -sf http://127.0.0.1:7072/health >/dev/null 2>&1; then
    info "A-FORGE reachable at :7072 — would seal via forge_vault (manual op recommended)"
    SEALED=1
elif curl -sf http://127.0.0.1:8088/health >/dev/null 2>&1; then
    info "arifOS reachable at :8088 — would seal via arif_seal (manual op recommended)"
    SEALED=1
else
    warn "Neither A-FORGE :7072 nor arifOS :8088 reachable — seal skipped"
fi
ok "Phase 9: $([ $SEALED -eq 1 ] && echo 'seal path available' || echo 'seal skipped (no MCP)')"

# ── FINAL SUMMARY ─────────────────────────────────────────────────────────
echo ""
echo "╔═══════════════════════════════════════════════════════════════╗"
echo "║  ✅ FORGE END v${VERSION} — Complete                            ║"
echo "╠═══════════════════════════════════════════════════════════════╣"
echo "║  Date:         ${DATE} ${TIMESTAMP} UTC                        "
echo "║  Agent:        ${AGENT} (${FI_SLOT})                          "
echo "║  Phases:       ${PHASE_OK}/${PHASE_TOTAL} passed              "
echo "║  Phases:       ${PHASE_FAIL} failed                           "
echo "║  Repos committed: ${COMMITTED}                                "
echo "║  SOT touched:  ${SOT_UPDATED}                                "
echo "║  State file:   ${STATE_FILE} (next-agent handoff)"
echo "║  Prev state:   ${STATE_PREV} (F1 AMANAH backup)"
echo "║  Seal path:    $([ $SEALED -eq 1 ] && echo 'available' || echo 'unavailable')"
echo "╠═══════════════════════════════════════════════════════════════╣"
echo "║  DITEMPA BUKAN DIBERI — The atlas outlives the cartographer.   ║"
echo "╚═══════════════════════════════════════════════════════════════╝"
echo ""

# F4 CLARITY: overall verdict
if [ $PHASE_FAIL -eq 0 ] && [ $COMMITTED -gt 0 ]; then
    echo "  ✅ forge-end: clean close, state handed off, no orphans"
    exit 0
elif [ $PHASE_FAIL -eq 0 ]; then
    echo "  ✅ forge-end: clean close, no repos to commit (already clean)"
    exit 0
else
    echo "  ⚠️  forge-end: $PHASE_FAIL phase(s) failed — review above"
    exit 1
fi
