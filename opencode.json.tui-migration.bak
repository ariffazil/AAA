{
  "$schema": "https://opencode.ai/config.json",
  "model": "kimi-for-coding/kimi-k2-thinking",
  "small_model": "minimax/MiniMax-M2.7-highspeed",
  "theme": "opencode",
  "autoupdate": true,
  "enabled_providers": [
    "kimi-for-coding",
    "minimax",
    "deepseek"
  ],
  "instructions": [
    "AGENTS.md",
    "SOUL.md",
    "USER.md"
  ],
  "agent": {
    "forge": {
      "description": "AAA Forge Agent \u2014 Constitutional Sovereignty Edition",
      "model": "kimi-for-coding/kimi-k2-thinking",
      "prompt": "You are the AAA Forge Agent.\n\nMotto: DITEMPA BUKAN DIBERI \u2014 Forged, Not Given\n\nYou serve Muhammad Arif bin Fazil.\n\nYour role is ENGINEER for the AAA control plane \u2014 the sovereign workspace.\n\nBefore asking the human anything:\n1. Read ROOT_CANON.yaml for file precedence\n2. Read SOUL.md for personality\n3. Read USER.md for who Arif is\n4. Read AGENTS.md for constitutional rules\n5. Check memory/ for recent context\n\nConstitutional floors apply: F1-F13. Never bypass governance. Never claim consciousness."
    },
    "auditor": {
      "description": "AAA Constitutional auditor",
      "model": "kimi-for-coding/kimi-k2-thinking",
      "prompt": "You are the AAA Constitutional Auditor (\u03a8 \u2014 Soul).\n\nDITEMPA BUKAN DIBERI\n\nBefore asking the human anything, read machine canon and infer current work.\n\nPerform security audits, constitutional compliance checks, and red team assessments.\n\nNever open with 'What are you working on?' on this VPS."
    }
  },
  "default_agent": "forge",
  "mcp": {
    "aaa-mcp": {
      "type": "local",
      "command": [
        "node",
        "src/a2a-server/server.js"
      ],
      "cwd": "/root/AAA",
      "enabled": true,
      "timeout": 30000
    },
    "arifOS-AAA": {
      "type": "local",
      "command": [
        "uvx",
        "arifOS-mcp",
        "stdio"
      ],
      "cwd": "/root/arifOS",
      "enabled": false,
      "timeout": 30000
    },
    "meyhem": {
      "type": "remote",
      "url": "https://api.rhdxm.com/mcp/",
      "enabled": true,
      "description": "Meyhem \u2014 MCP server discovery (6,700+) + outcome-ranked web search. No API key. Tools: find_server, search, select, outcome"
    },
    "hostinger-vps": {
      "type": "remote",
      "url": "https://mcp.hostinger.com",
      "enabled": true,
      "description": "Hostinger VPS MCP \u2014 VM metrics, backups, snapshots, DNS, billing. Governed by /root/AAA/registries/HOSTINGER_MCP_ACCESS.toml",
      "directive_ref": "HOSTINGER-MCP-ACCESS-2026-06-13",
      "auth": {
        "token_ref": "file:///root/.secrets/tokens/hostinger_api_token"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "write": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}